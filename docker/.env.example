# Copier en `.env` à côté du compose puis ajuster.
# docker compose --env-file .env -f docker/docker-compose.mercure.yml up -d

# Secret HMAC partagé entre publishers et subscribers (≥ 32 caractères).
# DOIT être identique à `realtime.mercure.jwtSecret` côté JavaFX
# (src/main/resources/realtime.properties), sinon tous les JWT seront rejetés.
MERCURE_JWT_SECRET=oxyn-dev-secret-change-me-please-use-32+chars

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="880.0" prefWidth="1530.0" styleClass="app-root" stylesheets="@../css/sidebar.css,@../css/topbar.css,@../css/home.css,@../css/cards.css,@../css/dashboard-saas.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.MainLayoutController">

    <left>
        <VBox fx:id="sidebar" maxHeight="Infinity" maxWidth="288" prefWidth="272" spacing="0" styleClass="sidebar">

            <Region maxWidth="Infinity" prefHeight="2" styleClass="sidebar-sheen" />

            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="brand">
                <padding>
                    <Insets bottom="18" left="14" right="16" top="18" />
                </padding>

                <Button fx:id="brandHomeButton" maxWidth="Infinity" onAction="#handleBrandHome" styleClass="brand-home-btn" text="" HBox.hgrow="ALWAYS">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane styleClass="brand-logo-glow-wrap">
                                <ImageView fitHeight="52.0" fitWidth="52.0" pickOnBounds="true" preserveRatio="true" styleClass="brand-logo-image">
                                    <image>
                                        <Image url="@../images/oxynLogo.png" />
                                    </image>
                                </ImageView>
                            </StackPane>
                            <VBox fx:id="brandTextColumn" spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="brand-name" text="OXYN" />
                                <Region maxWidth="44" prefHeight="3" prefWidth="44" styleClass="brand-accent" />
                                <Label styleClass="brand-tagline" text="Operations &amp; events platform" />
                            </VBox>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <Button fx:id="toggleButton" onAction="#handleToggleMenu" styleClass="sidebar-toggle">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-bars" iconSize="16" styleClass="sidebar-toggle-icon" />
                        <Label fx:id="toggleText" styleClass="toggle-text" text="Collapse sidebar" />
                    </HBox>
                </graphic>
            </Button>

            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                <VBox spacing="14" styleClass="managements">
                    <padding>
                        <Insets bottom="12" left="14" right="14" top="12" />
                    </padding>

                    <Label fx:id="shellModeLabel" styleClass="nav-title" text="MODE" />

                    <VBox fx:id="adminNavGroup" spacing="6">
                        <Label styleClass="nav-title" text="BACK OFFICE" />

                        <Button fx:id="adminDashboardBtn" onAction="#handleAdminDashboard" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-chart-pie" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Dashboard" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="stockMgmtBtn" onAction="#handleStockManagement" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-warehouse" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Stock Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="eventMgmtBtn" onAction="#handleEventManagement" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-calendar-check" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Event Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="userMgmtBtn" onAction="#handleUserManagement" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-users" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="User Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="reportsBtn" onAction="#handleReports" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-chart-line" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Reports / Statistics" />
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>

                    <VBox fx:id="clientNavGroup" spacing="6">
                        <Label styleClass="nav-title" text="FRONT OFFICE" />

                        <Button fx:id="clientHomeBtn" onAction="#handleClientHome" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-home" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Home" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="clientEventsBtn" onAction="#handleClientEvents" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-calendar-alt" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Events" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="clientPlanningBtn" onAction="#handlePlanning" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-calendar" iconSize="18" styleClass="nav-icon-fa" />
                                    <Label styleClass="nav-label" text="Planning" />
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </ScrollPane>

            <VBox fx:id="sidebarActionsBox" spacing="6" styleClass="sidebar-actions">
                <Button fx:id="profileBtn" onAction="#handleProfile" styleClass="nav-link">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-user" iconSize="18" styleClass="nav-icon-fa" />
                            <Label styleClass="nav-label" text="Profile" />
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="nav-link logout-btn">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-sign-out-alt" iconSize="18" styleClass="nav-icon-fa" />
                            <Label styleClass="nav-label" text="Logout" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <HBox fx:id="sidebarFooter" alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-foot sidebar-status">
                <padding>
                    <Insets bottom="16" left="20" right="20" top="14" />
                </padding>
                <Region prefHeight="8" prefWidth="8" styleClass="pulse-dot" />
                <Label fx:id="footerText" styleClass="sidebar-status-label" text="Connected" />
            </HBox>

        </VBox>
    </left>

    <center>
        <BorderPane styleClass="main-shell-center">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
                    <padding>
                        <Insets bottom="0" left="0" right="24" top="0" />
                    </padding>

                    <Label fx:id="topbarPageTitle" styleClass="topbar-page-title" text="Dashboard" />

                    <Region HBox.hgrow="ALWAYS" />

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-wrap">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="topbar-search-icon" />
                        <TextField fx:id="topbarSearchField" promptText="Search modules, events, stock…" styleClass="topbar-search" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region prefWidth="8" />

                    <Button fx:id="notificationBtn" onAction="#handleNotifications" styleClass="topbar-icon-btn" text="">
                        <graphic>
                            <FontIcon iconLiteral="fas-bell" iconSize="18" />
                        </graphic>
                    </Button>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="topbar-user-chip">
                        <StackPane styleClass="topbar-avatar">
                            <Label fx:id="userAvatarLabel" text="A" />
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="topbarUserName" styleClass="topbar-user-name" text="User" />
                            <Label fx:id="topbarUserRole" styleClass="topbar-user-role" text="Admin" />
                        </VBox>
                    </HBox>
                </HBox>
            </top>
            <center>
                <StackPane fx:id="contentArea" styleClass="content-area" />
            </center>
        </BorderPane>
    </center>

</BorderPane>

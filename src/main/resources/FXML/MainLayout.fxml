<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.MainLayoutController"
            prefHeight="800.0" prefWidth="1400.0"
            stylesheets="@../css/sidebar.css,@../css/home.css,@../css/cards.css">

    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" spacing="0"
              prefWidth="280" maxWidth="280" maxHeight="Infinity">

            <HBox fx:id="brandSection" styleClass="brand" alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="24" right="20  " bottom="24" left="20" />
                </padding>

                <!-- <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
                -->

                <VBox fx:id="brandText" HBox.hgrow="ALWAYS">
                    <Label text="AgriSense 360" styleClass="brand-name" />
                    <Label text="Smart AI Companion for Farms" styleClass="brand-tagline" />
                </VBox>

                <StackPane>
                    <Button fx:id="floatingButton" text="🌾" onAction="#handleFloatingButton"
                            style="-fx-min-width:40px;-fx-min-height:40px;
                                   -fx-max-width:40px;-fx-max-height:40px;
                                   -fx-background-radius:50;-fx-border-radius:50;
                                   -fx-background-color:rgba(255,255,255,0.18);
                                   -fx-text-fill:white;-fx-font-size:18px;
                                   -fx-alignment:CENTER;
                                   -fx-cursor:hand;-fx-border-width:0;
                                   -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.25),6,0,0,2);"/>
                    <Label fx:id="notificationDot" text="1"
                           visible="false" managed="false"
                           StackPane.alignment="TOP_RIGHT"
                           translateX="4" translateY="-4"
                           style="-fx-background-color:#e53935;-fx-text-fill:white;
                                  -fx-font-size:9px;-fx-font-weight:bold;
                                  -fx-min-width:16;-fx-min-height:16;
                                  -fx-max-width:20;-fx-max-height:16;
                                  -fx-background-radius:8;-fx-alignment:CENTER;
                                  -fx-padding:0 3 0 3;"/>
                </StackPane>
            </HBox>

            <Button fx:id="toggleButton" styleClass="sidebar-toggle" onAction="#handleToggleMenu">
                <graphic>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="toggleIcon" text="☰" style="-fx-font-size: 18px; -fx-text-fill: #a0d6a0;"/>
                        <Label fx:id="toggleText" text="Toggle menu" styleClass="toggle-text" />
                    </HBox>
                </graphic>
            </Button>

            <ScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="sidebar-scroll"
                        VBox.vgrow="ALWAYS">

                <VBox styleClass="managements" spacing="5">
                    <padding>
                        <Insets top="20" right="15" bottom="10" left="15" />
                    </padding>

                    <Label fx:id="navTitle" text="MANAGEMENTS" styleClass="nav-title" />

                    <VBox spacing="5">
                        <Button fx:id="homeBtn" styleClass="nav-link" onAction="#handleHome">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🏠" />
                                    <Label fx:id="homeLabel" text="Home" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="animalsBtn" styleClass="nav-link" onAction="#handleAnimals"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🐄" />
                                    <Label fx:id="animalsLabel" text="Animals Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="equipmentBtn" styleClass="nav-link" onAction="#handleEquipment"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🚜" />
                                    <Label fx:id="equipmentLabel" text="Equipments Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="stockBtn" styleClass="nav-link" onAction="#handleStock"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="📦" />
                                    <Label fx:id="stockLabel" text="Stock Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnBOS" styleClass="nav-link" onAction="#handleBackofficeStock">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🏢" />
                                    <Label fx:id="BOStockLabel" text="Backoffice Stock" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cultureBtn" styleClass="nav-link" onAction="#handleCulture"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🌱" />
                                    <Label fx:id="cultureLabel" text="Culture Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="usersBtn" styleClass="nav-link" onAction="#handleUsers"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="👤" />
                                    <Label fx:id="usersLabel" text="User Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="workersBtn" styleClass="nav-link" onAction="#handleWorkers"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="👷" />
                                    <Label fx:id="workersLabel" text="Workers Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="ouvrierBtn" styleClass="nav-link" onAction="#handleOuvrier"
                                visible="false" managed="false">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="👨‍🔧" />
                                    <Label fx:id="ouvrierLabel" text="Ouvrier Management" styleClass="nav-label" />
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </ScrollPane>

            <VBox spacing="5" style="-fx-padding: 10 15 10 15;">
                <Button fx:id="profileBtn" styleClass="nav-link" onAction="#handleProfile">
                    <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="👨‍💼" />
                            <Label fx:id="profileLabel" text="Profile" styleClass="nav-label" />
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="logoutBtn" styleClass="nav-link logout-btn" onAction="#handleLogout">
                    <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 22px; -fx-min-width: 28px;" text="🚪" />
                            <Label fx:id="logoutLabel" text="Logout" styleClass="nav-label" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <HBox fx:id="sidebarFooter" styleClass="sidebar-foot" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="16" left="20" right="20" top="16" />
                </padding>
                <Region styleClass="pulse-dot" prefWidth="8" prefHeight="8"
                        style="-fx-background-color: #4caf50; -fx-background-radius: 50%;"/>
                <Label fx:id="footerText" text="Connected" style="-fx-text-fill: #a0d6a0; -fx-font-size: 11px;"/>
            </HBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f4f6f0;"/>
    </center>

</BorderPane>
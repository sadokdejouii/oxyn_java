<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1400.0" styleClass="app-root" stylesheets="@../css/sidebar.css,@../css/home.css,@../css/cards.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.example.controllers.MainLayoutController">

    <left>
        <VBox fx:id="sidebar" maxHeight="Infinity" maxWidth="288" prefWidth="288" spacing="0" styleClass="sidebar">

            <Region maxWidth="Infinity" prefHeight="2" styleClass="sidebar-sheen" />

            <HBox fx:id="brandSection" alignment="CENTER_LEFT" spacing="12" styleClass="brand">
                <padding>
                    <Insets bottom="24" left="20" right="20" top="24" />
                </padding>

                <!-- <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
                -->

                <VBox fx:id="brandText" spacing="0" HBox.hgrow="ALWAYS">
                    <Label styleClass="brand-name" text="AgriSense 360" />
                    <Region maxWidth="44" prefHeight="3" prefWidth="44" styleClass="brand-accent" />
                    <Label styleClass="brand-tagline" text="Smart AI Companion for Farms" />
                </VBox>

                <StackPane styleClass="brand-fab-wrap">
                    <Button fx:id="floatingButton" onAction="#handleFloatingButton" styleClass="brand-fab" text="🌾" />
                    <Label fx:id="notificationDot" managed="false" styleClass="notification-badge" text="1" translateX="4" translateY="-4" visible="false" StackPane.alignment="TOP_RIGHT" />
                </StackPane>
            </HBox>

            <Button fx:id="toggleButton" onAction="#handleToggleMenu" styleClass="sidebar-toggle">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="toggleIcon" styleClass="toggle-glyph" text="☰" />
                        <Label fx:id="toggleText" styleClass="toggle-text" text="Toggle menu" />
                    </HBox>
                </graphic>
            </Button>

            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                <VBox spacing="6" styleClass="managements">
                    <padding>
                        <Insets bottom="12" left="16" right="16" top="22" />
                    </padding>

                    <Label fx:id="navTitle" styleClass="nav-title" text="MANAGEMENTS" />

                    <VBox spacing="6">
                        <Button fx:id="homeBtn" onAction="#handleHome" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="🏠" />
                                    <Label fx:id="homeLabel" styleClass="nav-label" text="Home" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="animalsBtn" managed="false" onAction="#handleAnimals" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="🐄" />
                                    <Label fx:id="animalsLabel" styleClass="nav-label" text="Animals Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="equipmentBtn" managed="false" onAction="#handleEquipment" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="🚜" />
                                    <Label fx:id="equipmentLabel" styleClass="nav-label" text="Equipments Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="stockBtn" managed="false" onAction="#handleStock" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="📦" />
                                    <Label fx:id="stockLabel" styleClass="nav-label" text="Stock Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnBOS" onAction="#handleBackofficeStock" styleClass="nav-link">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="🏢" />
                                    <Label fx:id="BOStockLabel" styleClass="nav-label" text="Backoffice Stock" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Label styleClass="nav-title" text="ESPACES &amp; OUTILS" />

                        <VBox spacing="6">
                            <Button fx:id="evenementBtn" onAction="#handleEvenement" styleClass="nav-link">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label styleClass="nav-emoji" text="📅" />
                                        <Label fx:id="evenementLabel" styleClass="nav-label" text="Événement" />
                                    </HBox>
                                </graphic>
                            </Button>

                            <Button fx:id="salleBtn" onAction="#handleSalle" styleClass="nav-link">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label styleClass="nav-emoji" text="🏛️" />
                                        <Label fx:id="salleLabel" styleClass="nav-label" text="Salle" />
                                    </HBox>
                                </graphic>
                            </Button>

                            <Button fx:id="planningBtn" onAction="#handlePlanning" styleClass="nav-link">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label styleClass="nav-emoji" text="🗓️" />
                                        <Label fx:id="planningLabel" styleClass="nav-label" text="Planning" />
                                    </HBox>
                                </graphic>
                            </Button>

                            <Button fx:id="boutiqueBtn" onAction="#handleBoutique" styleClass="nav-link">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label styleClass="nav-emoji" text="🛍️" />
                                        <Label fx:id="boutiqueLabel" styleClass="nav-label" text="Boutique" />
                                    </HBox>
                                </graphic>
                            </Button>

                            <Button fx:id="forumBtn" onAction="#handleForum" styleClass="nav-link">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label styleClass="nav-emoji" text="💬" />
                                        <Label fx:id="forumLabel" styleClass="nav-label" text="Forum" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>

                        <Button fx:id="cultureBtn" managed="false" onAction="#handleCulture" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="🌱" />
                                    <Label fx:id="cultureLabel" styleClass="nav-label" text="Culture Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="usersBtn" managed="false" onAction="#handleUsers" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="👤" />
                                    <Label fx:id="usersLabel" styleClass="nav-label" text="User Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="workersBtn" managed="false" onAction="#handleWorkers" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="👷" />
                                    <Label fx:id="workersLabel" styleClass="nav-label" text="Workers Management" />
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="ouvrierBtn" managed="false" onAction="#handleOuvrier" styleClass="nav-link" visible="false">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label styleClass="nav-emoji" text="👨‍🔧" />
                                    <Label fx:id="ouvrierLabel" styleClass="nav-label" text="Ouvrier Management" />
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </ScrollPane>

            <VBox spacing="6" styleClass="sidebar-actions">
                <Button fx:id="profileBtn" onAction="#handleProfile" styleClass="nav-link">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label styleClass="nav-emoji" text="👨‍💼" />
                            <Label fx:id="profileLabel" styleClass="nav-label" text="Profile" />
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="nav-link logout-btn">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label styleClass="nav-emoji" text="🚪" />
                            <Label fx:id="logoutLabel" styleClass="nav-label" text="Logout" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <HBox fx:id="sidebarFooter" alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-foot sidebar-status">
                <padding>
                    <Insets bottom="18" left="20" right="20" top="18" />
                </padding>
                <Region prefHeight="8" prefWidth="8" styleClass="pulse-dot" />
                <Label fx:id="footerText" styleClass="sidebar-status-label" text="Connected" />
            </HBox>

        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" />
    </center>

</BorderPane>

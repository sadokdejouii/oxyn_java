<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.ChatBotController"
            pickOnBounds="false">

    <Button fx:id="fabButton" text="💬" styleClass="fab-button"
            visible="false" managed="false"
            onAction="#toggleChat"
            AnchorPane.bottomAnchor="24.0"
            AnchorPane.rightAnchor="24.0"/>

    <VBox fx:id="chatWindow" styleClass="chat-window"
          visible="false" managed="false"
          maxWidth="380.0" maxHeight="520.0"
          AnchorPane.bottomAnchor="90.0"
          AnchorPane.rightAnchor="24.0">

        <HBox styleClass="chat-header" spacing="10.0" alignment="CENTER_LEFT">
            <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
            <Label text="🏋️" styleClass="avatar"/>
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                <Label text="Assistant OXYN" styleClass="header-title"/>
                <Label text="Salle de sport · IA" styleClass="header-subtitle"/>
            </VBox>
            <Button text="✕" styleClass="close-btn" onAction="#toggleChat"/>
        </HBox>

        <ScrollPane fx:id="scrollPane" fitToWidth="true"
                    styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox fx:id="messagesBox" styleClass="messages-container" spacing="10.0">
                <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
            </VBox>
        </ScrollPane>

        <Label fx:id="errorBanner" text=""
               visible="false" managed="false"
               styleClass="chat-error-banner"/>

        <HBox styleClass="input-area" spacing="8.0" alignment="CENTER">
            <padding><Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/></padding>
            <TextField fx:id="inputField" promptText="Votre message…"
                       styleClass="message-input" onAction="#sendMessage"
                       HBox.hgrow="ALWAYS"/>
            <Button fx:id="sendBtn" text="➤" styleClass="send-btn"
                    onAction="#sendMessage"/>
        </HBox>

    </VBox>

</AnchorPane>
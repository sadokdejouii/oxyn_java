<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.example.controllers.AbonnementController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: #f5f5f5;">
    
    <!-- En-tête -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="labelSalleInfo" text="Gestion des Abonnements" 
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Actualiser" onAction="#loadOffres" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>
    
    <!-- TableView des offres -->
    <VBox spacing="5">
        <Label text="Liste des offres d'abonnement" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        
        <TableView fx:id="tableViewOffres" prefHeight="300" 
                   style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="colNomOffre" text="Nom de l'offre" prefWidth="200"/>
                <TableColumn fx:id="colPrix" text="Prix (TND)" prefWidth="100"/>
                <TableColumn fx:id="colDuree" text="Durée (mois)" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="200"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        
        <Label fx:id="labelMessageVide" text="Aucun contenu dans la table" 
               style="-fx-text-fill: #999; -fx-font-style: italic;" visible="false"/>
    </VBox>
    
    <!-- Formulaire d'ajout/modification -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
        <Label text="Formulaire" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <Label text="Nom de l'offre :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="textFieldNomOffre" GridPane.rowIndex="0" GridPane.columnIndex="1" 
                       promptText="Ex: Abonnement Mensuel Standard" disable="true"
                       style="-fx-pref-width: 250;"/>
            
            <Label text="Prix (TND) :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="textFieldPrix" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                       promptText="Ex: 29.99" disable="true"
                       style="-fx-pref-width: 250;"/>
            
            <Label text="Durée (mois) :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="textFieldDuree" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                       promptText="Ex: 1" disable="true"
                       style="-fx-pref-width: 250;"/>
            
            <Label text="Description :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextArea fx:id="textAreaDescription" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                      promptText="Description détaillée de l'offre..." disable="true"
                      style="-fx-pref-width: 250; -fx-pref-height: 80;"/>
        </GridPane>
        
        <!-- Boutons d'action -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="buttonAjouter" text="+ Ajouter" onAction="#handleAjouter"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 100;"/>
            <Button fx:id="buttonModifier" text="Modifier" onAction="#handleModifier"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 100;" disable="true"/>
            <Button fx:id="buttonSupprimer" text="Supprimer" onAction="#handleSupprimer"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 100;" disable="true"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="buttonEnregistrer" text="Enregistrer" onAction="#handleEnregistrer"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 100;" disable="true"/>
            <Button fx:id="buttonAnnuler" text="Annuler" onAction="#handleAnnuler"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 100;" disable="true"/>
        </HBox>
    </VBox>
    
    <!-- Pied de page -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="💡 Astuce : Cliquez sur '+ Ajouter' pour créer une nouvelle offre d'abonnement" 
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Prêt" style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>
    </HBox>
    
</VBox>

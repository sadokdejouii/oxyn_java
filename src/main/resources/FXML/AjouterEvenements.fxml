<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AjouterEvenementsController">
   <children>
      <TextField fx:id="titre_evenement" layoutX="55.0" layoutY="14.0" promptText="titre" />
      <TextField fx:id="description_evenement" layoutX="65.0" layoutY="51.0" promptText="description" />
      <Button layoutX="248.0" layoutY="338.0" mnemonicParsing="false" onAction="#ajouterEvenement" text="ajouterEvenement" />
      <DatePicker fx:id="date_debut_evenement" layoutX="65.0" layoutY="88.0" promptText="date debut" />
      <DatePicker fx:id="date_fin_evenement" layoutX="73.0" layoutY="129.0" promptText="date fin" />
      <TextField fx:id="lieu_evenement" layoutX="98.0" layoutY="175.0" promptText="lieu_evenement" />
      <TextField fx:id="ville_evenement" layoutX="98.0" layoutY="214.0" promptText="ville_evenement" />
      <TextField fx:id="places_max_evenement" layoutX="98.0" layoutY="256.0" promptText="places_max_evenement" />
      <TextField fx:id="statut_evenement" layoutX="98.0" layoutY="299.0" promptText="statut_evenement" />
      <DatePicker fx:id="created_at_evenement" layoutX="345.0" layoutY="51.0" promptText="created_at_evenement" />
      <TextField fx:id="created_by_evenement" layoutX="345.0" layoutY="117.0" promptText="created_by_evenement" />
   </children>
</AnchorPane>

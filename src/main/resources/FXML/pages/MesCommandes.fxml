<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.MesCommandesController">
    <VBox spacing="18" styleClass="page-root">
        <padding>
            <Insets bottom="20" left="8" right="8" top="8" />
        </padding>

        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Mes commandes" />
            <Label styleClass="page-hero-sub" text="Historique de vos achats. Vous pouvez annuler une commande validée dans les 24 heures suivant la validation." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleRetourBoutique" styleClass="ghost-toolbar-btn" text="← Retour à la boutique" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="primary-toolbar-btn" text="Actualiser" />
        </HBox>

        <VBox fx:id="editAdressePanel" managed="false" spacing="14" styleClass="saas-chart-card mes-commandes-edit-panel" visible="false">
            <Label styleClass="saas-card-title" text="Modifier l’adresse de livraison" />
            <Label styleClass="product-form-hint" text="Même format que lors de la commande : quartier, ville, pays (trois parties séparées par des virgules). Exemple : cité Ibn Khaldoun, Tunis, Tunisie" wrapText="true" />
            <Label styleClass="product-form-field-label" text="Adresse de livraison" />
            <TextArea fx:id="editAdresseArea" prefRowCount="4" styleClass="form-input" wrapText="true" />
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleCancelEditAdresse" styleClass="ghost-toolbar-btn" text="Fermer" />
                <Button onAction="#handleSaveAdresse" styleClass="primary-toolbar-btn" text="Enregistrer" />
            </HBox>
        </VBox>

        <VBox fx:id="ordersContainer" spacing="14" />
    </VBox>
</ScrollPane>

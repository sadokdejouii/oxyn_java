<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane prefHeight="430.0" prefWidth="600.0" styleClass="front-modal-overlay" stylesheets="@../../css/front-events.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.FrontAvisFormPopupController">
    <VBox maxWidth="520.0" prefWidth="520.0" spacing="16" styleClass="front-modal-card">
        <Label fx:id="formTitleLabel" styleClass="front-modal-title" text="Ajouter un avis" />

        <VBox spacing="8">
            <Label styleClass="front-form-label" text="Note" />
            <ComboBox fx:id="noteCombo" promptText="Choisir une note" styleClass="front-modal-combo" />
        </VBox>

        <VBox spacing="8">
            <Label styleClass="front-form-label" text="Commentaire" />
            <TextArea fx:id="commentTextArea" prefHeight="150.0" promptText="Écrivez votre avis..." styleClass="front-modal-textarea" wrapText="true" />
        </VBox>

        <Label fx:id="feedbackLabel" styleClass="front-form-feedback" text="" />

        <HBox alignment="CENTER" spacing="10" styleClass="front-modal-actions">
            <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="front-modal-action-secondary" text="Annuler" />
            <Button mnemonicParsing="false" onAction="#handleSave" styleClass="front-modal-action-primary" text="Enregistrer" />
        </HBox>
    </VBox>
</StackPane>

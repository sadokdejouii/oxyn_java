<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            styleClass="front-events-scroll client-salle-surface-root"
            stylesheets="@../../css/front-events.css,@../../css/client-salle.css,@../../css/salle-planning.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.ClientSalleDetailController">
    <VBox alignment="TOP_CENTER" maxWidth="Infinity" spacing="22" styleClass="front-page client-salle-page">

        <HBox alignment="CENTER_LEFT" styleClass="client-salle-back-row">
            <Button fx:id="btnBack" onAction="#handleBack" styleClass="client-salle-back-btn" text="← Retour aux salles" />
        </HBox>

        <VBox spacing="16" styleClass="cl-detail-card client-salle-detail-hero">
            <padding>
                <Insets bottom="26" left="26" right="26" top="22" />
            </padding>

            <StackPane fx:id="photoPane" prefHeight="228" styleClass="cl-detail-photo-wrap client-salle-photo-frame">
                <ImageView fx:id="sallePhoto" fitWidth="900" fitHeight="228" preserveRatio="false" styleClass="cl-detail-photo" />
                <Label fx:id="photoPlaceholder" styleClass="cl-no-photo" text="Aucune photo" />
            </StackPane>

            <HBox alignment="TOP_LEFT" spacing="24">
                <VBox HBox.hgrow="ALWAYS" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="salleName" styleClass="cl-detail-title" text="—" />
                        <Label styleClass="front-status-chip front-status-active" text="Active" />
                    </HBox>
                    <Label fx:id="salleDesc" styleClass="cl-detail-desc" text="—" wrapText="true" />
                </VBox>
                <VBox minWidth="280" spacing="10" styleClass="client-salle-contact-block">
                    <Label fx:id="salleAddr" styleClass="cl-detail-info" text="—" wrapText="true" />
                    <Label fx:id="sallePhone" styleClass="cl-detail-info" text="—" />
                    <Label fx:id="salleEmail" styleClass="cl-detail-info" text="—" />
                    <Separator styleClass="client-salle-sep" />
                    <Label fx:id="salleRating" styleClass="cl-detail-rating" text="—" />
                    <Button fx:id="btnVoirPlanning" onAction="#handleVoirPlanning" styleClass="client-salle-planning-btn" text="📅 Voir le planning" />
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="12" styleClass="client-salle-section">
            <Label styleClass="cl-section-title" text="Abonnements disponibles" />
            <Label fx:id="noOffres" styleClass="cl-empty-label"
                   text="Aucun abonnement disponible pour cette salle." visible="false" managed="false" />
            <FlowPane fx:id="offresGrid" alignment="TOP_CENTER" hgap="18" prefWrapLength="1040" styleClass="front-events-grid client-salle-grid" vgap="18" />
        </VBox>

        <VBox spacing="12" styleClass="client-salle-section">
            <Label styleClass="cl-section-title" text="Sessions à venir" />
            <Label fx:id="noSessions" styleClass="cl-empty-label"
                   text="Aucune session planifiée pour cette salle." visible="false" managed="false" />
            <FlowPane fx:id="sessionsGrid" alignment="TOP_CENTER" hgap="18" prefWrapLength="1040" styleClass="front-events-grid client-salle-grid" vgap="18">
                <padding>
                    <Insets bottom="28" />
                </padding>
            </FlowPane>
        </VBox>

        <VBox spacing="12" styleClass="client-salle-section">
            <Label styleClass="cl-section-title" text="Localisation" />
            <WebView fx:id="mapView"
         prefWidth="1200"
         prefHeight="300"
         minWidth="800"
         minHeight="300"/>
        </VBox>

        <VBox fx:id="videoSection" spacing="12" styleClass="client-salle-section">
            <Label styleClass="cl-section-title" text="Vidéo YouTube" />
            <WebView fx:id="videoPlayer"
                     visible="false"
                     managed="false"
                     prefWidth="560"
                     prefHeight="315"
                     VBox.vgrow="NEVER" />
            <Label fx:id="videoLinkLabel"
                   text="▶ Voir la vidéo sur YouTube"
                   visible="false"
                   managed="false" />
            <Label fx:id="noVideoLabel"
                   styleClass="cl-empty-label"
                   text="Aucune vidéo disponible."
                   visible="true"
                   managed="true" />
        </VBox>

        <VBox spacing="12" styleClass="client-salle-section">
            <Label styleClass="cl-section-title" text="Votre avis" />
            <HBox fx:id="starsContainer" alignment="CENTER_LEFT" spacing="6" />
            <Label fx:id="ratingInfo" styleClass="cl-detail-info" text="Cliquez sur les étoiles pour noter" />
            <TextArea fx:id="commentArea" prefRowCount="3" promptText="Laissez un commentaire (optionnel)" wrapText="true" />
            <Button fx:id="submitRatingBtn" text="Soumettre ma note" />
            <Label fx:id="ratingMessage" styleClass="cl-empty-label" visible="false" managed="false" />
        </VBox>
    </VBox>
</ScrollPane>
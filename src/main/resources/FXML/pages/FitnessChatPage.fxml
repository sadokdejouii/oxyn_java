<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.example.controllers.FitnessChatController"
      spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 20px;">
    
    <!-- Header -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="🏋️‍♂️ Coach Fitness Virtuel" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🗑️ Vider chat" onAction="#clearChat" 
                style="-fx-background-color: #FF5722; -fx-text-fill: white; -fx-background-radius: 20;"/>
        <Button text="🔍 Test connexion" onAction="#testConnection" 
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 20;"/>
    </HBox>
    
    <!-- Zone de chat -->
    <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: white; -fx-background-radius: 15px; -fx-border-color: #E0E0E0; -fx-border-radius: 15px;">
        <VBox fx:id="chatMessagesContainer" spacing="10" style="-fx-padding: 15px;"/>
    </ScrollPane>
    
    <!-- Zone de saisie -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 15px; -fx-border-color: #E0E0E0; -fx-border-radius: 15px;">
        <TextArea fx:id="questionTextArea" 
                  promptText="Posez votre question sur le fitness..."
                  prefHeight="80" 
                  wrapText="true"
                  style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 10px; -fx-font-size: 14px;"/>
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="sendButton" text="📤 Envoyer" onAction="#sendQuestion"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25px; -fx-padding: 10 25;"/>
            
            <ProgressBar fx:id="loadingIndicator" progress="-1" visible="false"
                         style="-fx-accent: #4CAF50;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="statusLabel" text="Prêt à vous aider !" 
                   style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>
    
</VBox>

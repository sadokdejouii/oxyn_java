<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.example.discussion.ui.ChatLayout?>

<BorderPane styleClass="msg-page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.DiscussionPageController" maxWidth="Infinity" maxHeight="Infinity"
            stylesheets="@../../css/planning-saas-theme.css,@../../css/planning-discussion-page.css">
    <padding>
        <Insets top="20" right="24" bottom="24" left="24" />
    </padding>
    <top>
        <VBox spacing="6" styleClass="msg-page-hero">
            <Label styleClass="msg-page-title" text="Discussion" />
            <Label fx:id="subtitleLabel" styleClass="msg-page-sub" text="" wrapText="true" />
        </VBox>
    </top>
    <center>
        <ChatLayout maxWidth="Infinity" maxHeight="Infinity" styleClass="msg-chat-card">
            <children>
                <!-- Colonne liste (Messenger) -->
                <VBox fx:id="conversationSidebar" spacing="0" styleClass="msg-user-list" minWidth="280" prefWidth="300" maxWidth="320">
                    <VBox spacing="4" styleClass="msg-user-list-header">
                        <padding>
                            <Insets bottom="12" left="16" right="16" top="16" />
                        </padding>
                        <Label styleClass="msg-user-list-title" text="Discussions" />
                        <Label styleClass="msg-user-list-sub" text="Vos contacts" wrapText="true" />
                    </VBox>
                    <ListView fx:id="conversationList" VBox.vgrow="ALWAYS" styleClass="msg-user-listview" />
                </VBox>
                <!-- Colonne chat -->
                <VBox spacing="0" styleClass="msg-chat-column" maxWidth="Infinity" maxHeight="Infinity" HBox.hgrow="ALWAYS">
                    <VBox fx:id="chatHeaderMount" styleClass="msg-chat-header-wrap" maxWidth="Infinity" />
                    <ScrollPane fx:id="messagesScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                styleClass="msg-messages-scroll" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                        <VBox fx:id="messagesBox" styleClass="msg-messages-stack" maxWidth="Infinity" />
                    </ScrollPane>
                    <VBox fx:id="messageInputMount" styleClass="msg-input-dock-outer" maxWidth="Infinity" />
                </VBox>
            </children>
        </ChatLayout>
    </center>
    <bottom>
        <Label fx:id="statusLabel" styleClass="msg-page-status" text="" wrapText="true">
            <BorderPane.margin>
                <Insets top="10" left="4" right="4" bottom="0" />
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>

<BorderPane styleClass="forum-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ForumController"
            stylesheets="@../../css/forum.css">

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="16" styleClass="forum-main-content" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="40" bottom="30" left="48" right="48" />
            </padding>

            <!-- CREATE POST SECTION — compact -->
            <VBox styleClass="create-post-section" spacing="8">
                <VBox.margin>
                    <Insets top="15" bottom="15" left="10" right="10" />
                </VBox.margin>

                <!-- Inline header + controls row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✨ Nouveau post" styleClass="create-post-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="attachmentButton" text="📎 Joindre" styleClass="post-control-button" />
                    <Button fx:id="emojiButton" text="😊 Emoji" styleClass="post-control-button" />
                    <ComboBox fx:id="categoryComboBox" promptText="Catégorie" styleClass="post-category-combo" prefWidth="150" />
                    <Button fx:id="postButton" text="✓ Publier" styleClass="post-button-primary" />
                </HBox>

                <!-- Content Area — reduced height -->
                <TextArea fx:id="postContentArea" promptText="Partagez votre expérience avec la communauté..." prefRowCount="2" wrapText="true" styleClass="create-post-textarea" />
                <Label fx:id="postContentError" text="" styleClass="error-label" visible="false" />

                <!-- Attachment preview (hidden by default) -->
                <HBox fx:id="attachmentPreviewBox" spacing="8" alignment="CENTER_LEFT" />
                <Label fx:id="attachmentLabel" text="" styleClass="attachment-status-label" />
            </VBox>

            <!-- Filter & Controls — compact bar -->
            <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍 Rechercher..." prefHeight="32" prefWidth="180" styleClass="search-field" />

                <Separator orientation="VERTICAL" prefHeight="24" />

                <Label text="Catégorie:" styleClass="filter-label" />
                <ComboBox fx:id="categoriesFilterCombo" prefWidth="140" prefHeight="32" styleClass="sort-combo" />

                <Separator orientation="VERTICAL" prefHeight="24" />

                <Label text="Trier:" styleClass="filter-label" />
                <ComboBox fx:id="sortComboBox" prefWidth="140" prefHeight="32" styleClass="sort-combo" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Grid/List Toggle -->
                <HBox spacing="3" styleClass="view-toggle-box">
                    <Button fx:id="gridViewBtn" text="⊞" styleClass="view-button,grid-view-btn" prefWidth="32" prefHeight="32" />
                    <Button fx:id="listViewBtn" text="☰" styleClass="view-button,list-view-btn" prefWidth="32" prefHeight="32" />
                </HBox>
            </HBox>

            <!-- Posts Container -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="posts-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="postsContainer" spacing="12" styleClass="posts-container" />
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll,pp-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ProfilePageController">
    <VBox spacing="24" styleClass="page-root,pp-root">
        <padding>
            <Insets bottom="12" left="8" right="8" top="8" />
        </padding>

        <!-- Hero -->
        <HBox styleClass="pp-hero">
            <StackPane styleClass="pp-avatar-wrap">
                <Label fx:id="avatarLabel" styleClass="pp-avatar-text" text="?" />
            </StackPane>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label styleClass="pp-kicker" text="MON COMPTE" />
                <Label styleClass="page-hero-title,pp-title" text="Mon profil" />
                <Label fx:id="subtitleLabel" styleClass="page-hero-sub,pp-hero-sub" text="Chargement…" wrapText="true" />
            </VBox>
        </HBox>

        <VBox fx:id="readOnlyBanner" managed="false" styleClass="pp-banner-readonly" visible="false">
            <Label text="Profil en lecture seule. Les administrateurs modifient leur fiche depuis l’annuaire « Gestion des utilisateurs »." wrapText="true" />
        </VBox>

        <HBox styleClass="pp-columns">
            <!-- Account summary -->
            <VBox maxWidth="Infinity" styleClass="saas-chart-card,pp-card" HBox.hgrow="ALWAYS" minWidth="260">
                <Label styleClass="pp-card-head" text="IDENTITÉ DU COMPTE" />
                <VBox styleClass="pp-kv-list">
                    <VBox spacing="6" styleClass="pp-kv-row">
                        <Label styleClass="pp-kv-key" text="Adresse e-mail" />
                        <Label fx:id="emailValue" styleClass="pp-kv-val" text="—" wrapText="true" />
                    </VBox>
                    <VBox spacing="8" styleClass="pp-kv-row">
                        <Label styleClass="pp-kv-key" text="Statut du compte" />
                        <HBox spacing="10">
                            <Label fx:id="statusValue" styleClass="pp-inline-badge" text="—" />
                        </HBox>
                    </VBox>
                    <VBox spacing="8" styleClass="pp-kv-row,pp-kv-row-last">
                        <Label styleClass="pp-kv-key" text="Rôle" />
                        <HBox spacing="10">
                            <Label fx:id="roleValue" styleClass="pp-inline-badge" text="—" />
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Editable profile -->
            <VBox maxWidth="Infinity" styleClass="saas-chart-card,pp-card" HBox.hgrow="ALWAYS" minWidth="280">
                <Label styleClass="pp-card-head" text="COORDONNÉES PERSONNELLES" />
                <Label styleClass="pp-card-sub" text="Ces informations sont enregistrées sur votre fiche. Seuls le nom, le prénom et le téléphone peuvent être mis à jour ici (e-mail inchangé)." wrapText="true" />
                <VBox spacing="18" styleClass="pp-form-block">
                    <HBox spacing="16" styleClass="pp-form-row">
                        <VBox spacing="6" styleClass="pp-field-stack" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Nom *" />
                            <TextField fx:id="nomField" styleClass="login-field" />
                            <Label fx:id="nomErrorLabel" styleClass="field-error-msg" managed="false" visible="false" />
                        </VBox>
                        <VBox spacing="6" styleClass="pp-field-stack" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Prénom *" />
                            <TextField fx:id="prenomField" styleClass="login-field" />
                            <Label fx:id="prenomErrorLabel" styleClass="field-error-msg" managed="false" visible="false" />
                        </VBox>
                    </HBox>
                    <VBox spacing="6" styleClass="pp-field-stack">
                        <Label styleClass="field-label" text="Téléphone" />
                        <TextField fx:id="telephoneField" promptText="Optionnel" styleClass="login-field" />
                        <Label fx:id="telephoneErrorLabel" styleClass="field-error-msg" managed="false" visible="false" />
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_RIGHT" styleClass="pp-footer">
            <Label fx:id="formHintLabel" styleClass="pp-hint-muted" text="Les champs marqués * sont obligatoires." />
            <Button fx:id="saveButton" onAction="#handleSave" styleClass="primary-toolbar-btn,pp-save-btn" text="Enregistrer les modifications" />
        </HBox>
    </VBox>
</ScrollPane>

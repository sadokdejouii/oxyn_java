<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.EncadrantGroupeController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Mes Groupes" />
            <Label styleClass="page-hero-sub" text="Gérez les participants inscrits dans vos groupes d'encadrement." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Actualiser" />
            <HBox HBox.hgrow="ALWAYS" />
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Participants" />
            <TableView fx:id="groupeTable" prefHeight="460" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="nomColumn" prefWidth="200" text="Nom" />
                    <TableColumn fx:id="evenementColumn" prefWidth="200" text="Événement" />
                    <TableColumn fx:id="dateInscriptionColumn" prefWidth="160" text="Date inscription" />
                    <TableColumn fx:id="statutColumn" prefWidth="120" text="Statut" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AjouterProduitPageController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Ajouter un Produit" />
            <Label styleClass="page-hero-sub" text="Remplissez les informations ci-dessous pour ajouter un nouveau produit à la boutique." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleSave" styleClass="primary-toolbar-btn" text="Enregistrer" />
            <Button onAction="#handleCancel" styleClass="ghost-toolbar-btn" text="Annuler" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleClear" styleClass="ghost-toolbar-btn" text="Vider" />
        </HBox>

        <VBox spacing="20" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Informations du Produit" />
            
            <VBox spacing="15">
                <VBox spacing="5">
                    <Label styleClass="form-label" text="Nom du produit *" />
                    <TextField fx:id="nomField" promptText="Entrez le nom du produit" styleClass="form-input" />
                </VBox>

                <VBox spacing="5">
                    <Label styleClass="form-label" text="Description *" />
                    <TextArea fx:id="descriptionField" promptText="Entrez la description du produit" styleClass="form-input" prefHeight="80" wrapText="true" />
                </VBox>

                <HBox spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="Prix (TND) *" />
                        <TextField fx:id="prixField" promptText="0.00" styleClass="form-input" />
                    </VBox>

                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="Quantité en stock *" />
                        <TextField fx:id="quantiteField" promptText="0" styleClass="form-input" />
                    </VBox>
                </HBox>

                <VBox spacing="8">
                    <Label styleClass="form-label" text="Photo du produit" />
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <ImageView fx:id="imagePreview" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" styleClass="product-image" />
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Button onAction="#handleChooseImage" styleClass="ghost-toolbar-btn" text="Choisir une image…" />
                            <Label fx:id="imageFileLabel" styleClass="saas-stat-hint" text="Aucune image — le défaut « default.jpg » sera utilisé si présent dans /images." wrapText="true" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="5">
                    <Label styleClass="form-label" text="Statut *" />
                    <TextField fx:id="statutField" promptText="Disponible" styleClass="form-input" />
                </VBox>

                <VBox spacing="5">
                    <Label styleClass="form-label" text="Date de création" />
                    <TextField fx:id="dateField" promptText="Auto-générée" styleClass="form-input" disable="true" />
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>

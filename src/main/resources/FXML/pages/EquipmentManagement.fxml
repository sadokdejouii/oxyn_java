<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controllers.EquipmentController"
           maxWidth="Infinity" maxHeight="Infinity">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="apd-page-scroll" maxWidth="Infinity" maxHeight="Infinity">
        <VBox spacing="18" styleClass="apd-page-inner salle-mgmt-inner" maxWidth="Infinity">
            <VBox spacing="4">
                <Label styleClass="apd-section-title" text="Équipements" />
                <Label styleClass="apd-section-sub" text="Gérez les équipements par salle." wrapText="true"/>
            </VBox>

            <GridPane styleClass="apd-kpi-grid" hgap="14" vgap="14" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.34" />
                </columnConstraints>
                <VBox spacing="4" styleClass="apd-kpi-card apd-kpi-card--users" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="apd-kpi-label" text="TOTAL" />
                    <Label fx:id="statTotal" styleClass="apd-kpi-value" text="—" />
                    <Label styleClass="apd-kpi-hint" text="Équipements" wrapText="true" />
                </VBox>
                <VBox spacing="4" styleClass="apd-kpi-card apd-kpi-card--prog" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="apd-kpi-label" text="ACTIFS" />
                    <Label fx:id="statActifs" styleClass="apd-kpi-value" text="—" />
                    <Label styleClass="apd-kpi-hint" text="En service" wrapText="true" />
                </VBox>
                <VBox spacing="4" styleClass="apd-kpi-card apd-kpi-card--tasks" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label styleClass="apd-kpi-label" text="QUANTITÉ TOTALE" />
                    <Label fx:id="statQte" styleClass="apd-kpi-value" text="—" />
                    <Label styleClass="apd-kpi-hint" text="Unités" wrapText="true" />
                </VBox>
            </GridPane>

            <VBox spacing="12" styleClass="apd-filter-panel" maxWidth="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="Infinity">
                    <Button onAction="#handleAjouter" styleClass="apd-btn" text="+ Nouvel équipement" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="filterSalle" styleClass="apd-select" maxWidth="260" promptText="Toutes les salles" />
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ToggleButton fx:id="filterAll"      onAction="#handleFilter" styleClass="sess-filter-btn" text="Tous"     userData="ALL"      selected="true"/>
                    <ToggleButton fx:id="filterActive"   onAction="#handleFilter" styleClass="sess-filter-btn" text="Actifs"   userData="ACTIVE"/>
                    <ToggleButton fx:id="filterInactive" onAction="#handleFilter" styleClass="sess-filter-btn" text="Inactifs" userData="INACTIVE"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleRefresh" styleClass="apd-btn-ghost" text="Actualiser"/>
                </HBox>
            </VBox>

            <Label fx:id="countLabel" styleClass="apd-match-hint" text="0 équipement(s)"/>

            <FlowPane fx:id="equipGrid" hgap="16" vgap="16" prefWrapLength="1100" styleClass="apd-user-cards-flow" maxWidth="Infinity">
                <padding><Insets bottom="8" left="2" right="2" top="4"/></padding>
            </FlowPane>
        </VBox>
    </ScrollPane>

    <StackPane fx:id="dialogOverlay" visible="false" managed="false" styleClass="apd-detail-dim" maxWidth="Infinity" maxHeight="Infinity">
        <VBox maxWidth="500" spacing="14" styleClass="sess-dialog-card sess-dialog-card--apd" alignment="TOP_LEFT">
            <padding><Insets bottom="28" left="28" right="28" top="24"/></padding>
            <Label fx:id="dialogTitle" styleClass="sess-dialog-title" text="Nouvel équipement"/>
            <VBox spacing="5">
                <Label styleClass="sess-lbl" text="Nom *"/>
                <TextField fx:id="fieldName" promptText="Nom de l'équipement" styleClass="apd-field" maxWidth="Infinity"/>
            </VBox>
            <HBox spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="sess-lbl" text="Quantité *"/>
                    <TextField fx:id="fieldQty" promptText="ex: 10" styleClass="apd-field" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="sess-lbl" text="Salle *"/>
                    <ComboBox fx:id="fieldSalle" maxWidth="Infinity" styleClass="apd-select" promptText="Choisir une salle"/>
                </VBox>
            </HBox>
            <VBox spacing="5">
                <Label styleClass="sess-lbl" text="Description"/>
                <TextArea fx:id="fieldDesc" promptText="Description… (2000 caractères max.)" styleClass="apd-field" prefRowCount="3" maxWidth="Infinity" wrapText="true"/>
            </VBox>
            <Label styleClass="apd-section-sub" text="Quantité : entier entre 0 et 999999. Une salle doit être sélectionnée." wrapText="true"/>
            <Label fx:id="dialogError" styleClass="sess-error" text="" wrapText="true"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button onAction="#handleCancel"  styleClass="apd-btn-ghost"  text="Annuler"/>
                <Button onAction="#handleSave"    styleClass="apd-btn"    text="Enregistrer"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="confirmOverlay" visible="false" managed="false" styleClass="apd-detail-dim" maxWidth="Infinity" maxHeight="Infinity">
        <VBox maxWidth="380" spacing="16" styleClass="sess-confirm-card sess-confirm-card--apd" alignment="CENTER">
            <padding><Insets bottom="24" left="24" right="24" top="20"/></padding>
            <Label styleClass="sess-confirm-icon" text="!"/>
            <Label styleClass="sess-confirm-title" text="Supprimer l'équipement ?"/>
            <Label fx:id="confirmMsg" styleClass="apd-section-sub" text="" wrapText="true"/>
            <HBox spacing="12" alignment="CENTER">
                <Button onAction="#handleConfirmCancel" styleClass="apd-btn-ghost" text="Annuler"/>
                <Button onAction="#handleConfirmDelete" styleClass="sess-btn-danger" text="Supprimer"/>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ClientBoutiqueController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Notre Boutique" />
            <Label styleClass="page-hero-sub" text="Découvrez notre sélection de produits de qualité pour vos événements et besoins professionnels." wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar-card">
            <Label styleClass="product-form-field-label" text="Recherche" />
            <TextField fx:id="rechercheProduitsClient" onAction="#handleRechercheOuTriClient" prefWidth="200" promptText="Nom, prix, stock…" styleClass="topbar-search" HBox.hgrow="SOMETIMES" />
            <Label styleClass="product-form-field-label" text="Trier" />
            <ComboBox fx:id="triProduitsClient" onAction="#handleRechercheOuTriClient" prefWidth="200" />
            <Region prefWidth="8" />
            <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Actualiser" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleMesCommandes" styleClass="ghost-toolbar-btn" text="Mes commandes" />
            <Button onAction="#handlePanier" styleClass="primary-toolbar-btn" text="Mon panier" />
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Nos Produits" />
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="products-scroll">
                <TilePane fx:id="produitsContainer" hgap="20" vgap="20" alignment="TOP_LEFT" prefColumns="3" styleClass="products-grid">
                </TilePane>
            </ScrollPane>
        </VBox>
    </VBox>
</ScrollPane>

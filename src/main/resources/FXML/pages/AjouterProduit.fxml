<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AjouterProduitController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30" />
    </padding>

    <VBox spacing="10">
        <Label styleClass="page-hero-title" text="Ajouter un nouveau produit" />
        <Label styleClass="page-hero-sub" text="Remplissez les informations ci-dessous pour ajouter un produit à la boutique." wrapText="true" />
    </VBox>

    <VBox spacing="15" styleClass="saas-chart-card">
        <Label styleClass="saas-card-title" text="Informations du produit" />
        
        <VBox spacing="8">
            <Label text="Nom du produit *" styleClass="form-label" />
            <TextField fx:id="nomField" promptText="Entrez le nom du produit" styleClass="form-input" />
        </VBox>

        <VBox spacing="8">
            <Label text="Description *" styleClass="form-label" />
            <TextArea fx:id="descriptionArea" promptText="Entrez la description du produit" styleClass="form-input" prefHeight="80" wrapText="true" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Prix (TND) *" styleClass="form-label" />
                <TextField fx:id="prixField" promptText="0.00" styleClass="form-input" />
            </VBox>
            
            <VBox spacing="8">
                <Label text="Quantité en stock *" styleClass="form-label" />
                <TextField fx:id="quantiteField" promptText="0" styleClass="form-input" />
            </VBox>
        </HBox>

        <VBox spacing="8">
            <Label text="URL de l'image" styleClass="form-label" />
            <TextField fx:id="imageField" promptText="Entrez l'URL de l'image (optionnel)" styleClass="form-input" />
        </VBox>

        <VBox spacing="8">
            <Label text="Statut *" styleClass="form-label" />
            <TextField fx:id="statutField" promptText="Disponible, Indisponible, Rupture..." styleClass="form-input" />
        </VBox>
    </VBox>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button onAction="#handleAnnuler" styleClass="ghost-toolbar-btn" text="Annuler" />
        <Button onAction="#handleAjouter" styleClass="primary-toolbar-btn" text="Ajouter le produit" />
    </HBox>
</VBox>

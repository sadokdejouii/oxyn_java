<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.BoutiqueController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Boutique" />
            <Label styleClass="page-hero-sub" text="Gestion des produits et commandes. Ajoutez, modifiez ou supprimez des produits." wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleAjouterProduit" styleClass="primary-toolbar-btn" text="Ajouter un produit" />
            <Button onAction="#handleVoirCommandes" styleClass="ghost-toolbar-btn" text="Commandes clients" />
            <Label styleClass="product-form-field-label" text="Recherche" />
            <TextField fx:id="rechercheProduits" onAction="#handleRechercheOuTriProduits" prefWidth="180" promptText="Nom, description, statut…" styleClass="topbar-search" HBox.hgrow="SOMETIMES" />
            <Label styleClass="product-form-field-label" text="Trier" />
            <ComboBox fx:id="triProduits" onAction="#handleRechercheOuTriProduits" prefWidth="200" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Actualiser" />
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Liste des produits" />
            <ListView fx:id="produitsListView" prefHeight="420" styleClass="list-view data-list boutique-admin-pro-list" />
        </VBox>
    </VBox>
</ScrollPane>

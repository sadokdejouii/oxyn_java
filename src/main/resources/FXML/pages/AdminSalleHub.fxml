<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.AdminSalleHubController"
      styleClass="sh-root" spacing="0"
      stylesheets="@../../css/salle-hub.css">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sh-page-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="20" styleClass="sh-page-inner">

            <!-- ── HERO ── -->
            <VBox styleClass="sh-hero" spacing="8">
                <Label styleClass="sh-eyebrow" text="ADMINISTRATION · SALLE DE SPORT" />
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label styleClass="sh-title" text="Gestion de la Salle" />
                        <Label styleClass="sh-sub" wrapText="true"
                               text="Pilotez vos salles, équipements et offres d'abonnement depuis un seul tableau de bord." />
                    </VBox>
                    <Button onAction="#handleRefresh" styleClass="sh-btn-refresh" text="Actualiser">
                        <tooltip><Tooltip text="Recharger les données" /></tooltip>
                    </Button>
                </HBox>
                <Region styleClass="sh-sep-hero" prefHeight="1" maxWidth="Infinity" />
            </VBox>

            <!-- ── KPI ROW ── -->
            <HBox spacing="14" styleClass="sh-kpi-row">
                <VBox spacing="4" styleClass="sh-kpi-card sh-kpi-card--salles" HBox.hgrow="ALWAYS">
                    <Label styleClass="sh-kpi-label" text="SALLES" />
                    <Label fx:id="badgeSalles" styleClass="sh-kpi-value" text="—" />
                    <Label styleClass="sh-kpi-hint" text="Salles enregistrées" wrapText="true" />
                </VBox>
                <VBox spacing="4" styleClass="sh-kpi-card sh-kpi-card--equip" HBox.hgrow="ALWAYS">
                    <Label styleClass="sh-kpi-label" text="ÉQUIPEMENTS" />
                    <Label fx:id="badgeEquip" styleClass="sh-kpi-value" text="—" />
                    <Label styleClass="sh-kpi-hint" text="Matériels en service" wrapText="true" />
                </VBox>
                <VBox spacing="4" styleClass="sh-kpi-card sh-kpi-card--subs" HBox.hgrow="ALWAYS">
                    <Label styleClass="sh-kpi-label" text="ABONNEMENTS" />
                    <Label fx:id="badgeSubs" styleClass="sh-kpi-value" text="—" />
                    <Label styleClass="sh-kpi-hint" text="Offres disponibles" wrapText="true" />
                </VBox>
            </HBox>

            <!-- ── CONTENT BLOCK ── -->
            <VBox styleClass="sh-content-block" spacing="0" VBox.vgrow="ALWAYS">

                <!-- Tab bar -->
                <HBox styleClass="sh-tab-bar" spacing="0" alignment="BOTTOM_LEFT">

                    <VBox fx:id="tabSalles" onMouseClicked="#handleTab"
                          styleClass="sh-tab,sh-tab-active" spacing="0" minWidth="160">
                        <HBox alignment="CENTER" spacing="10" styleClass="sh-tab-inner">
                            <Label styleClass="sh-tab-icon" text="🏢" />
                            <Label styleClass="sh-tab-label" text="Salles" />
                        </HBox>
                        <Region fx:id="indSalles" styleClass="sh-tab-indicator-active" prefHeight="3" maxWidth="Infinity" />
                    </VBox>

                    <VBox fx:id="tabEquip" onMouseClicked="#handleTab"
                          styleClass="sh-tab" spacing="0" minWidth="180">
                        <HBox alignment="CENTER" spacing="10" styleClass="sh-tab-inner">
                            <Label styleClass="sh-tab-icon" text="🏋" />
                            <Label styleClass="sh-tab-label" text="Équipements" />
                        </HBox>
                        <Region fx:id="indEquip" styleClass="sh-tab-indicator" prefHeight="3" maxWidth="Infinity" />
                    </VBox>

                    <VBox fx:id="tabSubs" onMouseClicked="#handleTab"
                          styleClass="sh-tab" spacing="0" minWidth="180">
                        <HBox alignment="CENTER" spacing="10" styleClass="sh-tab-inner">
                            <Label styleClass="sh-tab-icon" text="💳" />
                            <Label styleClass="sh-tab-label" text="Abonnements" />
                        </HBox>
                        <Region fx:id="indSubs" styleClass="sh-tab-indicator" prefHeight="3" maxWidth="Infinity" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Tab content -->
                <StackPane fx:id="hubContent" styleClass="sh-hub-content" VBox.vgrow="ALWAYS" />

            </VBox>

        </VBox>
    </ScrollPane>

</VBox>

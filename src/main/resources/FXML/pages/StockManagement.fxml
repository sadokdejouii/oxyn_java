<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.StockManagementController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Stock management" />
            <Label styleClass="page-hero-sub" text="Monitor SKUs, batches, and stock movements. Sample data is shown until inventory is connected." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleAdd" styleClass="primary-toolbar-btn" text="Add SKU" />
            <Button onAction="#handleEdit" styleClass="ghost-toolbar-btn" text="Edit" />
            <Button onAction="#handleDelete" styleClass="ghost-toolbar-btn" text="Delete" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Refresh" />
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Inventory" />
            <TableView fx:id="stockTable" prefHeight="420" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="skuColumn" prefWidth="120" text="SKU" />
                    <TableColumn fx:id="nameColumn" prefWidth="220" text="Product" />
                    <TableColumn fx:id="qtyColumn" prefWidth="90" text="Qty" />
                    <TableColumn fx:id="siteColumn" prefWidth="140" text="Site" />
                    <TableColumn fx:id="statusColumn" prefWidth="120" text="Status" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

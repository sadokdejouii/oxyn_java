<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controllers.SubscriptionController">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll">
        <VBox spacing="20" styleClass="page-root">

            <VBox spacing="4">
                <Label styleClass="page-hero-title" text="Abonnements" />
                <Label styleClass="page-hero-sub" text="Gerez les offres d'abonnement par salle." wrapText="true"/>
            </VBox>

            <HBox spacing="14" styleClass="saas-stat-row">
                <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="saas-stat-label" text="TOTAL OFFRES" />
                    <Label fx:id="statTotal" styleClass="saas-stat-value" text="—" />
                    <Label styleClass="saas-stat-hint" text="Toutes offres" />
                </VBox>
                <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="saas-stat-label" text="ACTIVES" />
                    <Label fx:id="statActives" styleClass="saas-stat-value" text="—" />
                    <Label styleClass="saas-stat-hint" text="Disponibles" />
                </VBox>
                <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="saas-stat-label" text="PRIX MOYEN" />
                    <Label fx:id="statPrix" styleClass="saas-stat-value" text="—" />
                    <Label styleClass="saas-stat-hint" text="TND / offre" />
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-card">
                <Button onAction="#handleAjouter" styleClass="primary-toolbar-btn" text="+ Nouvel offre" />
                <Region HBox.hgrow="ALWAYS"/>
                <ToggleButton fx:id="filterAll"      onAction="#handleFilter" styleClass="sess-filter-btn" text="Toutes"    userData="ALL"      selected="true"/>
                <ToggleButton fx:id="filterActive"   onAction="#handleFilter" styleClass="sess-filter-btn" text="Actives"   userData="ACTIVE"/>
                <ToggleButton fx:id="filterInactive" onAction="#handleFilter" styleClass="sess-filter-btn" text="Inactives" userData="INACTIVE"/>
                <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Actualiser"/>
            </HBox>

            <Label fx:id="countLabel" styleClass="saas-stat-label" text="0 offre(s)"/>

            <FlowPane fx:id="offersGrid" hgap="18" vgap="18" prefWrapLength="1000">
                <padding><Insets bottom="24" left="2" right="2" top="4"/></padding>
            </FlowPane>
        </VBox>
    </ScrollPane>

    <!-- DIALOG -->
    <StackPane fx:id="dialogOverlay" visible="false" managed="false" styleClass="sess-overlay">
        <VBox maxWidth="480" spacing="14" styleClass="sess-dialog-card" alignment="TOP_LEFT">
            <padding><Insets bottom="28" left="28" right="28" top="24"/></padding>
            <Label fx:id="dialogTitle" styleClass="sess-dialog-title" text="Nouvelle offre"/>
            <VBox spacing="5">
                <Label styleClass="sess-lbl" text="Nom de l'offre *"/>
                <TextField fx:id="fieldName" promptText="ex: Abonnement mensuel" styleClass="sess-field" maxWidth="Infinity"/>
            </VBox>
            <HBox spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="sess-lbl" text="Duree (mois) *"/>
                    <TextField fx:id="fieldDuration" promptText="ex: 1" styleClass="sess-field" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="sess-lbl" text="Prix (TND) *"/>
                    <TextField fx:id="fieldPrice" promptText="0.00" styleClass="sess-field" maxWidth="Infinity"/>
                </VBox>
            </HBox>
            <VBox spacing="5">
                <Label styleClass="sess-lbl" text="Salle"/>
                <ComboBox fx:id="fieldSalle" maxWidth="Infinity" styleClass="sess-field" promptText="Aucune salle"/>
            </VBox>
            <VBox spacing="5">
                <Label styleClass="sess-lbl" text="Description"/>
                <TextArea fx:id="fieldDesc" promptText="Description de l'offre..." styleClass="sess-field" prefRowCount="3" maxWidth="Infinity" wrapText="true"/>
            </VBox>
            <Label fx:id="dialogError" styleClass="sess-error" text="" wrapText="true"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button onAction="#handleCancel" styleClass="sess-btn-cancel" text="Annuler"/>
                <Button onAction="#handleSave"   styleClass="sess-btn-save"   text="Enregistrer"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- ORDERS PANEL -->
    <StackPane fx:id="ordersOverlay" visible="false" managed="false" styleClass="sess-overlay">
        <VBox maxWidth="620" spacing="14" styleClass="sess-dialog-card" alignment="TOP_LEFT">
            <padding><Insets bottom="28" left="28" right="28" top="24"/></padding>
            <Label styleClass="sess-dialog-title" text="Commandes liees"/>
            <TableView fx:id="ordersTable" prefHeight="320" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colOrderId"   prefWidth="60"  text="ID"/>
                    <TableColumn fx:id="colUserId"    prefWidth="80"  text="User"/>
                    <TableColumn fx:id="colQty"       prefWidth="70"  text="Qte"/>
                    <TableColumn fx:id="colUnitPrice" prefWidth="90"  text="Prix unit."/>
                    <TableColumn fx:id="colTotal"     prefWidth="90"  text="Total"/>
                    <TableColumn fx:id="colStatus"    prefWidth="100" text="Statut"/>
                    <TableColumn fx:id="colDate"      prefWidth="140" text="Date"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#handleCloseOrders" styleClass="sess-btn-cancel" text="Fermer"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- CONFIRM DELETE -->
    <StackPane fx:id="confirmOverlay" visible="false" managed="false" styleClass="sess-overlay">
        <VBox maxWidth="360" spacing="16" styleClass="sess-confirm-card" alignment="CENTER">
            <padding><Insets bottom="24" left="24" right="24" top="20"/></padding>
            <Label styleClass="sess-confirm-icon" text="!"/>
            <Label styleClass="sess-confirm-title" text="Supprimer l'offre ?"/>
            <Label fx:id="confirmMsg" styleClass="page-hero-sub" text="" wrapText="true"/>
            <HBox spacing="12" alignment="CENTER">
                <Button onAction="#handleConfirmCancel" styleClass="sess-btn-cancel" text="Annuler"/>
                <Button onAction="#handleConfirmDelete" styleClass="sess-btn-danger"  text="Supprimer"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-events-scroll" stylesheets="@../../css/front-events.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.FrontEventsController">
    <VBox spacing="22" styleClass="front-page">
        

        <StackPane styleClass="front-hero-banner">
            <VBox alignment="CENTER" spacing="8">
                <Label styleClass="front-banner-title" text="Événements" />
                <Label styleClass="front-banner-subtitle" text="Découvrez nos événements" />
                <Label styleClass="front-banner-text" text="Explorez facilement les activités sportives, bien-être et loisirs qui vous correspondent." wrapText="true" />
            
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="12" styleClass="front-toolbar">
            <TextField fx:id="searchField" promptText="Rechercher par titre, ville, lieu ou statut..." styleClass="front-search" />
            <ComboBox fx:id="sortCombo" promptText="Trier par" styleClass="front-sort" />
        </HBox>

        <FlowPane fx:id="eventsContainer" hgap="18" prefWrapLength="1040" styleClass="front-events-grid" vgap="18" />
    </VBox>
</ScrollPane>

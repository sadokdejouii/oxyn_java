<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.UserManagementController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="User management" />
            <Label styleClass="page-hero-sub" text="Provision accounts and roles. Demo data is shown until a user directory is wired in." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleInvite" styleClass="primary-toolbar-btn" text="Invite user" />
            <Button onAction="#handleResetRole" styleClass="ghost-toolbar-btn" text="Change role" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="ghost-toolbar-btn" text="Refresh" />
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Directory" />
            <TableView fx:id="usersTable" prefHeight="460" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="emailColumn" prefWidth="260" text="Email" />
                    <TableColumn fx:id="nameColumn" prefWidth="200" text="Name" />
                    <TableColumn fx:id="roleColumn" prefWidth="120" text="Role" />
                    <TableColumn fx:id="statusColumn" prefWidth="120" text="Status" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>

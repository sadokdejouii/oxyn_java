<?xml version="1.0" encoding="UTF-8"?>



<?import javafx.geometry.Insets?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.control.CheckBox?>

<?import javafx.scene.control.Label?>

<?import javafx.scene.control.ProgressBar?>

<?import javafx.scene.control.ScrollPane?>

<?import javafx.scene.control.TextArea?>

<?import javafx.scene.layout.ColumnConstraints?>

<?import javafx.scene.layout.GridPane?>

<?import javafx.scene.layout.HBox?>

<?import javafx.scene.layout.Region?>

<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.layout.VBox?>

<?import org.kordamp.ikonli.javafx.FontIcon?>



<!-- Supervision encadrant : client · fiche · programme · progression · IA · observation -->

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"

      fx:controller="org.example.controllers.EncadrantPlanningDashboardController"

      styleClass="planning-dash-root epd-root epd-root--supervision" spacing="20" maxWidth="Infinity"

      stylesheets="@../../css/planning-saas-theme.css,@../../css/planning-widgets.css,@../../css/encadrant-planning-dashboard.css">

    <padding>

        <Insets top="30" right="30" bottom="40" left="30" />

    </padding>





    <GridPane styleClass="planning-dash-grid" hgap="20" vgap="20" maxWidth="Infinity" VBox.vgrow="ALWAYS">

        <columnConstraints>

            <ColumnConstraints hgrow="ALWAYS" minWidth="120" prefWidth="200" percentWidth="25" />

            <ColumnConstraints hgrow="ALWAYS" minWidth="120" prefWidth="200" percentWidth="25" />

            <ColumnConstraints hgrow="ALWAYS" minWidth="120" prefWidth="200" percentWidth="25" />

            <ColumnConstraints hgrow="ALWAYS" minWidth="120" prefWidth="200" percentWidth="25" />

        </columnConstraints>



        <!-- 1. Carte client (identité + indicateurs programme) -->

        <VBox styleClass="w-card planning-dash-card epd-client-card" maxWidth="Infinity" spacing="16"

              GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="4">

            <HBox alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-client-card__icon">

                    <FontIcon iconLiteral="fas-user-tie" iconSize="18" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS" spacing="4">

                    <Label styleClass="epd-client-card__title" text="Client supervisé" />

                    <Label styleClass="epd-client-card__subtitle" text="Identité et statut de suivi — données en lecture seule" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--readonly" text="Supervision" />

            </HBox>

            <GridPane hgap="24" vgap="12" styleClass="epd-client-grid">

                <columnConstraints>

                    <ColumnConstraints hgrow="SOMETIMES" minWidth="160" prefWidth="240" percentWidth="34" />

                    <ColumnConstraints hgrow="SOMETIMES" minWidth="180" prefWidth="320" percentWidth="38" />

                    <ColumnConstraints hgrow="SOMETIMES" minWidth="140" prefWidth="280" percentWidth="28" />

                </columnConstraints>

                <VBox styleClass="epd-kv-block" spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">

                    <Label styleClass="epd-kv-block__k" text="Nom" />

                    <Label fx:id="lblClientName" styleClass="epd-kv-block__v" wrapText="true" text="—" />

                </VBox>

                <VBox styleClass="epd-kv-block" spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">

                    <Label styleClass="epd-kv-block__k" text="E-mail" />

                    <Label fx:id="lblClientEmail" styleClass="epd-kv-block__v epd-kv-block__v--mono" wrapText="true" text="—" />

                </VBox>

                <VBox styleClass="epd-kv-block" spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">

                    <Label styleClass="epd-kv-block__k" text="Statut (objectif semaine)" />

                    <Label fx:id="lblClientStatut" styleClass="epd-kv-block__v epd-kv-block__v--statut" wrapText="true" text="—" />

                </VBox>

            </GridPane>

            <Region styleClass="epd-divider" prefHeight="1" maxWidth="Infinity" />

            <HBox styleClass="epd-client-metrics" alignment="TOP_LEFT" spacing="28">

                <VBox spacing="4" styleClass="epd-metric-chip">

                    <Label styleClass="epd-metric-chip__k" text="Calories / jour" />

                    <Label fx:id="lblDashCalories" styleClass="epd-metric-chip__v" wrapText="true" text="—" />

                </VBox>

                <VBox spacing="4" styleClass="epd-metric-chip">

                    <Label styleClass="epd-metric-chip__k" text="Objectif programme" />

                    <Label fx:id="lblDashObjectifProg" styleClass="epd-metric-chip__v" wrapText="true" text="—" />

                </VBox>

                <VBox spacing="4" styleClass="epd-metric-chip">

                    <Label styleClass="epd-metric-chip__k" text="Niveau d'activité" />

                    <Label fx:id="lblDashActivite" styleClass="epd-metric-chip__v" wrapText="true" text="—" />

                </VBox>

            </HBox>

        </VBox>



        <!-- 2. Fiche santé -->

        <VBox styleClass="w-card planning-dash-card epd-fiche-card" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="4">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-section-icon">

                    <FontIcon iconLiteral="fas-heartbeat" iconSize="18" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Fiche santé" />

                    <Label styleClass="w-card__subtitle" text="Profil biométrique et objectifs — consultation" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--neutral" text="Référence" />

            </HBox>

            <VBox styleClass="w-card__body" spacing="14">

                <GridPane hgap="14" vgap="14" styleClass="w-kv-grid epd-fiche-grid">

                    <columnConstraints>

                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="140" />

                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="140" />

                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="140" />

                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="140" />

                    </columnConstraints>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="0" GridPane.rowIndex="0">

                        <Label styleClass="w-kv-tile__label" text="Genre" />

                        <Label fx:id="lblGenre" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="1" GridPane.rowIndex="0">

                        <Label styleClass="w-kv-tile__label" text="Âge" />

                        <Label fx:id="lblAge" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="2" GridPane.rowIndex="0">

                        <Label styleClass="w-kv-tile__label" text="Taille" />

                        <Label fx:id="lblTaille" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="3" GridPane.rowIndex="0">

                        <Label styleClass="w-kv-tile__label" text="Poids" />

                        <Label fx:id="lblPoids" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">

                        <Label styleClass="w-kv-tile__label" text="Objectif" />

                        <Label fx:id="lblObjectif" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                    <VBox styleClass="w-kv-tile epd-kv-tile" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.columnSpan="2">

                        <Label styleClass="w-kv-tile__label" text="Activité" />

                        <Label fx:id="lblActivite" styleClass="w-kv-tile__value" wrapText="true" />

                    </VBox>

                </GridPane>

            </VBox>

        </VBox>



        <!-- 3. Programme (lecture) | Tâches -->

        <VBox styleClass="w-card w-card--programme planning-dash-card epd-programme-card" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="3">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-section-icon">

                    <FontIcon iconLiteral="fas-clipboard-list" iconSize="18" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Programme généré" />

                    <Label styleClass="w-card__subtitle" text="Entraînement et nutrition — consultation uniquement" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--readonly" text="Lecture seule" />

            </HBox>

            <VBox styleClass="w-card__body" spacing="12" VBox.vgrow="ALWAYS">

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="w-scroll epd-scroll" maxHeight="720" minViewportHeight="280" VBox.vgrow="ALWAYS">

                    <VBox fx:id="programmeStructuredHost" spacing="12" />

                </ScrollPane>

            </VBox>

        </VBox>

        <VBox styleClass="w-card planning-dash-card epd-tasks-card" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="2">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="10">

                <StackPane styleClass="w-card__icon-wrap epd-section-icon">

                    <FontIcon iconLiteral="fas-check-double" iconSize="16" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Tâches" />

                    <Label styleClass="w-card__subtitle" text="Semaine en cours" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--neutral" text="Suivi" />

            </HBox>

            <VBox styleClass="w-card__body" spacing="12" VBox.vgrow="ALWAYS">

                <VBox fx:id="tasksContainer" spacing="10" VBox.vgrow="ALWAYS" />

            </VBox>

        </VBox>



        <!-- 4. Progression (prioritaire) -->

        <VBox styleClass="w-card planning-dash-card epd-progress-card" maxWidth="Infinity" spacing="0"

              GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="4">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-progress-card__icon">

                    <FontIcon iconLiteral="fas-chart-line" iconSize="18" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Progression hebdomadaire" />

                    <Label styleClass="w-card__subtitle" text="Complétion des tâches — indicateur principal pour la décision" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--accent" text="Priorité" />

            </HBox>

            <VBox styleClass="w-card__body epd-progress-body" spacing="14">

                <Label styleClass="epd-progress-hint" wrapText="true"

                       text="Seuil d’appréciation : ≥ 75 % favorable (vert), 40–74 % à surveiller (orange), &lt; 40 % faible (rouge)." />

                <HBox alignment="CENTER_LEFT" spacing="20">

                    <Label fx:id="lblDashProgressPct" styleClass="epd-progress-pct" text="—" />

                    <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity">

                        <ProgressBar fx:id="progressDashSummary" maxWidth="Infinity" prefHeight="14" minHeight="14"

                                     styleClass="epd-pbar epd-pbar--na" progress="0" />

                        <Label fx:id="lblDashProgressDetail" styleClass="epd-progress-detail" wrapText="true" text="" />

                    </VBox>

                </HBox>

            </VBox>

        </VBox>



        <!-- 5. Synthèse IA -->

        <VBox styleClass="w-card planning-dash-card epd-ia-card" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="4">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-ia-card__icon">

                    <FontIcon iconLiteral="fas-robot" iconSize="18" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Synthèse IA" />

                    <Label styleClass="w-card__subtitle" text="Analyse structurée — génération locale, ton professionnel" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--ia" text="Assistant" />

            </HBox>

            <VBox styleClass="w-card__body epd-ia-body" spacing="10" VBox.vgrow="ALWAYS">

                <Label styleClass="epd-ia-disclaimer" wrapText="true"

                       text="Document d’aide à la décision : vérifier les données source avant toute action auprès du client." />

                <TextArea fx:id="txtIa" editable="false" wrapText="true" styleClass="epd-ia-synthese" prefRowCount="12" maxWidth="Infinity" VBox.vgrow="ALWAYS" />

            </VBox>

        </VBox>



        <!-- 6. Observation encadrant -->

        <VBox styleClass="w-card planning-dash-card epd-obs-card" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="4">

            <HBox styleClass="w-card__header" alignment="CENTER_LEFT" spacing="14">

                <StackPane styleClass="w-card__icon-wrap epd-obs-card__icon">

                    <FontIcon iconLiteral="fas-pen-fancy" iconSize="17" styleClass="w-card__icon" />

                </StackPane>

                <VBox styleClass="w-card__titles" HBox.hgrow="ALWAYS">

                    <Label styleClass="w-card__title epd-section-title" text="Observation encadrant" />

                    <Label styleClass="w-card__subtitle" text="Message persisté sur l’objectif hebdomadaire du client" />

                </VBox>

                <Label styleClass="epd-pill epd-pill--obs" text="Édition" />

            </HBox>

            <VBox styleClass="w-card__body epd-obs-body" spacing="12">

                <Label fx:id="lblObsHint" styleClass="epd-obs-hint" wrapText="true" />

                <TextArea fx:id="txtObservation" wrapText="true" styleClass="epd-obs-textarea" prefRowCount="6" maxWidth="Infinity" />

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <CheckBox fx:id="chkEfforts" mnemonicParsing="false" text="Efforts validés" selected="true" styleClass="w-check epd-check" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnRefresh" mnemonicParsing="false" text="Actualiser" styleClass="w-btn-secondary epd-btn-secondary" />

                    <Button fx:id="btnSaveObs" mnemonicParsing="false" text="Intervenir" styleClass="w-btn-primary epd-btn-save" />

                </HBox>

            </VBox>

        </VBox>

    </GridPane>

</VBox>


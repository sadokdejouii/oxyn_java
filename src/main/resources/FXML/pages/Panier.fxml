<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.PanierController">
    <VBox spacing="18" styleClass="page-root">
        <padding>
            <Insets bottom="20" left="8" right="8" top="8" />
        </padding>

        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Mon panier" />
            <Label styleClass="page-hero-sub" text="Récapitulatif de vos articles, livraison et paiement. Validez lorsque tout est correct." wrapText="true" />
        </VBox>

        <HBox spacing="10" styleClass="toolbar-card">
            <Button onAction="#handleRetourBoutique" styleClass="ghost-toolbar-btn" text="← Retour à la boutique" />
            <HBox HBox.hgrow="ALWAYS" />
        </HBox>

        <VBox spacing="14" styleClass="saas-chart-card">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="saas-card-title" text="Vos articles" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="panierCountLabel" styleClass="panier-badge-count" text="0 article" />
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="380" styleClass="panier-lignes-scroll" vbarPolicy="AS_NEEDED">
                <VBox fx:id="panierLignesContainer" spacing="12" styleClass="panier-lignes-list" />
            </ScrollPane>

            <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="panier-total-bar">
                <Label styleClass="panier-total-libelle" text="Total TTC" />
                <Label fx:id="totalLabel" styleClass="panier-total-montant" text="0,00 TND" />
            </HBox>
        </VBox>

        <!-- Même structure que les formulaires produit (product-form) -->
        <VBox styleClass="product-form-section">
            <VBox styleClass="product-form-section-head">
                <Label styleClass="product-form-section-kicker" text="LIVRAISON" />
                <Label styleClass="product-form-section-title" text="Adresse et paiement" />
                <Label styleClass="product-form-hint" text="Adresse au format : quartier, ville, pays (trois parties séparées par des virgules, max. 255 caractères)." wrapText="true" />
            </VBox>
            <Separator styleClass="product-form-separator" />
            <VBox styleClass="product-form-section-body">
                <VBox spacing="6">
                    <Label styleClass="product-form-field-label" text="Adresse de livraison *" />
                    <TextArea fx:id="adresseField" prefRowCount="3" promptText="Ex. cité Ibn Khaldoun, Tunis, Tunisie" styleClass="form-input" wrapText="true" />
                </VBox>
                <VBox spacing="6">
                    <Label styleClass="product-form-field-label" text="Mode de paiement *" />
                    <ComboBox fx:id="paiementCombo" prefWidth="320" styleClass="form-input" />
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button fx:id="validerBtn" onAction="#handleValiderCommande" styleClass="primary-toolbar-btn" text="Valider la commande" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>

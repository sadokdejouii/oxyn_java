<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" stylesheets="@../css/product-form.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.PanierController">
    <VBox alignment="TOP_CENTER" styleClass="page-root product-form-page product-form-outer">
        <VBox spacing="20" styleClass="product-form-shell">
            <padding>
                <Insets bottom="8" left="4" right="4" top="8" />
            </padding>

            <VBox spacing="8" styleClass="product-form-hero">
                <Label styleClass="page-hero-title" text="Passer la commande" />
                <Label styleClass="page-hero-sub" text="Vérifiez vos articles, renseignez l’adresse de livraison et le mode de paiement, puis validez." wrapText="true" />
                <Label styleClass="product-form-required-legend" text="* Champs obligatoires" />
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar-card product-form-toolbar">
                <Button onAction="#handleRetourBoutique" styleClass="ghost-toolbar-btn" text="← Retour à la boutique" />
                <HBox HBox.hgrow="ALWAYS" />
            </HBox>

            <VBox spacing="14" styleClass="panier-recap-card">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4">
                        <Label styleClass="product-form-section-kicker" text="RÉCAPITULATIF" />
                        <Label styleClass="product-form-section-title" text="Vos articles" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="panierCountLabel" styleClass="panier-badge-count" text="0 article" />
                </HBox>
                <Separator styleClass="product-form-separator" />
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="380" styleClass="panier-lignes-scroll" vbarPolicy="AS_NEEDED">
                    <VBox fx:id="panierLignesContainer" spacing="12" styleClass="panier-lignes-list" />
                </ScrollPane>
                <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="panier-total-bar">
                    <Label styleClass="panier-total-libelle" text="Total TTC" />
                    <Label fx:id="totalLabel" styleClass="panier-total-montant" text="0,00 TND" />
                </HBox>
            </VBox>

            <VBox styleClass="product-form-section">
                <VBox styleClass="product-form-section-head">
                    <Label styleClass="product-form-section-kicker" text="LIVRAISON" />
                    <Label styleClass="product-form-section-title" text="Adresse et paiement" />
                    <Label styleClass="product-form-hint" text="Adresse au format : quartier, ville, pays (trois parties séparées par des virgules, max. 255 caractères)." wrapText="true" />
                </VBox>
                <Separator styleClass="product-form-separator" />
                <VBox styleClass="product-form-section-body">
                    <VBox spacing="6">
                        <Label styleClass="product-form-field-label" text="Adresse de livraison *" />
                        <TextArea fx:id="adresseField" prefRowCount="4" promptText="Ex. cité Ibn Khaldoun, Tunis, Tunisie" styleClass="form-input" wrapText="true" />
                    </VBox>
                    <GridPane hgap="20" styleClass="product-form-grid" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" prefWidth="280" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="160" prefWidth="220" />
                        </columnConstraints>
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="product-form-field-label" text="Mode de paiement *" />
                            <ComboBox fx:id="paiementCombo" maxWidth="Infinity" styleClass="form-input" />
                        </VBox>
                        <VBox alignment="BOTTOM_RIGHT" spacing="0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Button fx:id="validerBtn" onAction="#handleValiderCommande" styleClass="primary-toolbar-btn" text="Valider la commande" />
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>

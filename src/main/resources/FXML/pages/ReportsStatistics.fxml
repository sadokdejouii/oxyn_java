<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ReportsStatisticsController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Reports &amp; statistics" />
            <Label styleClass="page-hero-sub" text="Export-ready summaries for leadership reviews. Values blend live KPIs with illustrative series." wrapText="true" />
        </VBox>

        <HBox spacing="16" alignment="TOP_LEFT">
            <VBox spacing="10" styleClass="saas-chart-card" HBox.hgrow="ALWAYS">
                <Label styleClass="saas-card-title" text="Throughput by channel" />
                <BarChart fx:id="barChart" animated="false" legendVisible="false" prefHeight="300" styleClass="saas-chart" categoryGap="12" barGap="4">
                    <xAxis>
                        <CategoryAxis label="Channel" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Volume" autoRanging="true" />
                    </yAxis>
                </BarChart>
            </VBox>
            <VBox spacing="10" styleClass="saas-chart-card" prefWidth="360">
                <Label styleClass="saas-card-title" text="Outcome mix" />
                <PieChart fx:id="pieChart" labelsVisible="true" legendVisible="true" prefHeight="300" styleClass="saas-chart" />
            </VBox>
        </HBox>

        <VBox spacing="8" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Notes" />
            <Label styleClass="page-hero-sub" text="Wire these charts to your warehouse and CRM feeds. CSV/PDF export can be added at the service layer." wrapText="true" />
        </VBox>
    </VBox>
</ScrollPane>

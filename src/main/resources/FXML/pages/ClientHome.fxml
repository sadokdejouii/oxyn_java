<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ClientHomeController">
    <VBox spacing="18" styleClass="page-root">
        <VBox spacing="6">
            <Label styleClass="page-hero-title" text="Welcome back" />
            <Label styleClass="page-hero-sub" text="A lightweight overview of upcoming events and your recent engagement." wrapText="true" />
        </VBox>

        <HBox spacing="14" styleClass="saas-stat-row">
            <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                <Label styleClass="saas-stat-label" text="OPEN EVENTS" />
                <Label fx:id="miniEventsLabel" styleClass="saas-stat-value" text="—" />
                <Label styleClass="saas-stat-hint" text="You can register" />
            </VBox>
            <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                <Label styleClass="saas-stat-label" text="THIS WEEK" />
                <Label fx:id="miniPlansLabel" styleClass="saas-stat-value" text="—" />
                <Label styleClass="saas-stat-hint" text="Planning items" />
            </VBox>
            <VBox spacing="4" styleClass="saas-stat-card" HBox.hgrow="ALWAYS">
                <Label styleClass="saas-stat-label" text="NOTIFICATIONS" />
                <Label fx:id="miniNotifLabel" styleClass="saas-stat-value" text="—" />
                <Label styleClass="saas-stat-hint" text="Unread highlights" />
            </VBox>
        </HBox>

        <VBox spacing="10" styleClass="saas-chart-card">
            <Label styleClass="saas-card-title" text="Your activity (last weeks)" />
            <LineChart fx:id="sparkLineChart" animated="false" legendVisible="false" prefHeight="240" styleClass="saas-chart">
                <xAxis>
                    <CategoryAxis label="Week" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Engagement" autoRanging="true" />
                </yAxis>
            </LineChart>
        </VBox>

        <VBox spacing="0" styleClass="saas-activity-card">
            <padding>
                <Insets bottom="8" left="0" right="0" top="12" />
            </padding>
            <Label styleClass="saas-card-title">
                <padding>
                    <Insets bottom="6" left="18" right="18" top="0" />
                </padding>
                <text>Highlights</text>
            </Label>
            <VBox fx:id="clientHighlights" spacing="0" />
        </VBox>
    </VBox>
</ScrollPane>

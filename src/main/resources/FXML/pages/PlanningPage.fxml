<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:id="planningPageStack" styleClass="planning-page-stack" stylesheets="@../../css/planning-saas-theme.css,@../../css/planning-module.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.PlanningPageController">
    <ScrollPane fx:id="planningPageScroll" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll">
        <VBox fx:id="planningRoot" spacing="0" styleClass="planning-page-root">
            <VBox fx:id="planningMainShell" styleClass="planning-main-shell" spacing="20" maxWidth="Infinity">
                <HBox styleClass="planning-top-header" alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <HBox styleClass="planning-hero-title-row" alignment="CENTER_LEFT" spacing="12">
                            <Label styleClass="planning-hero-title" text="Planning" />
                            <Label fx:id="roleBadge" styleClass="planning-role-badge" text="" />
                        </HBox>
                        <Label fx:id="heroSub" styleClass="planning-hero-sub" text="Chargement…" wrapText="true" />
                        <Label styleClass="planning-hero-meta" text="Fiche santé · Programme · Tâches · IA · Discussion" wrapText="true" />
                    </VBox>
                    <StackPane styleClass="planning-user-avatar-wrap">
                        <Circle radius="23" styleClass="planning-user-avatar-ring" />
                        <Circle radius="20" styleClass="planning-user-avatar-fill" />
                        <Label fx:id="avatarInitials" styleClass="planning-user-avatar-text" text="?" />
                    </StackPane>
                </HBox>
                <VBox fx:id="dynamicContainer" spacing="18" styleClass="planning-dynamic" maxWidth="Infinity" VBox.vgrow="ALWAYS" />
            </VBox>
        </VBox>
    </ScrollPane>
    <Button focusTraversable="false" onAction="#handleOpenDiscussion" styleClass="planning-discussion-fab" StackPane.alignment="BOTTOM_RIGHT" text="">
        <StackPane.margin>
            <Insets bottom="28" right="28" />
        </StackPane.margin>
        <graphic>
            <FontIcon iconLiteral="fas-comments" iconSize="22" styleClass="planning-fab-icon" />
        </graphic>
    </Button>
</StackPane>
